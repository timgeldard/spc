# SPC App — local development environment variables
# Copy this file to .env and fill in your values.
# Never commit a populated .env file.

# ── Databricks connection ──────────────────────────────────────────────────────

# Workspace URL. Automatically injected by Databricks Apps runtime in production.
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net

# HTTP path of your SQL Warehouse.
# Found in: Databricks workspace > SQL Warehouses > <warehouse> > Connection details
DATABRICKS_WAREHOUSE_HTTP_PATH=/sql/1.0/warehouses/YOUR_WAREHOUSE_ID

# ── Unity Catalog coordinates ──────────────────────────────────────────────────

# Catalog and schema containing the gold views used by both modules.
TRACE_CATALOG=connected_plant_uat
TRACE_SCHEMA=gold

# ── Optional tuning ────────────────────────────────────────────────────────────

# Maximum depth for the batch traceability recursive CTE (default: 10).
# MAX_TRACE_LEVELS=10
